# functions/.env.staging — server-side env vars for the staging Firebase project
# Firebase Functions reads this file when deploying to the staging project.
# Never commit real credentials.

# TODO: Replace with the staging Google Spreadsheet ID
# (the long string in the URL: https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit)
SPREADSHEET_ID=TODO_STAGING_SPREADSHEET_ID

# TODO: Replace with the service account email for the staging project
# (client_email from the JSON key file)
GOOGLE_SERVICE_ACCOUNT_EMAIL=TODO_SERVICE_ACCOUNT_EMAIL@TODO_STAGING_PROJECT_ID.iam.gserviceaccount.com

# TODO: Replace with the service account private key for the staging project
# (private_key from the JSON key file — keep the \n characters, wrap in double quotes)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="TODO_PRIVATE_KEY"
