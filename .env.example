# Expense Tracker — Environment Variables
# Copy this file to .env (production) and .env.local (staging/dev)
# Fill in the values for your environment. Never commit .env or .env.local.

# ─────────────────────────────────────────────
# Firebase (Next.js client — all NEXT_PUBLIC_)
# Get these from Firebase Console > Project Settings > Your apps > Web app
# ─────────────────────────────────────────────

# Firebase API key (identifies your Firebase project)
NEXT_PUBLIC_FIREBASE_API_KEY=

# Firebase Auth domain (e.g., your-project-id.firebaseapp.com)
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=

# Firebase project ID (e.g., your-project-id)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Firebase Storage bucket (e.g., your-project-id.appspot.com)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Firebase Messaging sender ID (numeric, e.g., 123456789012)
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Firebase App ID (e.g., 1:123456789012:web:abc123def456)
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─────────────────────────────────────────────
# Google Sheets (Firebase Functions — server only, never expose to client)
# See SETUP.md for how to create the service account and Spreadsheet
# ─────────────────────────────────────────────

# Google Spreadsheet ID — the long string in the Spreadsheet URL
# (e.g., https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit)
GOOGLE_SPREADSHEET_ID=

# Google service account email (e.g., expense-tracker@your-project.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Google service account private key — the full JSON key value including BEGIN/END markers
# In .env files, wrap in double quotes and replace literal newlines with \n
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
