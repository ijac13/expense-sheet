# app/.env.staging — Next.js client env vars for the staging Firebase project
# Get all values from Firebase Console > Project Settings > Your apps > Web app
# for the staging project.
# Never commit real credentials.

# TODO: Replace with the staging project's Firebase API key
NEXT_PUBLIC_FIREBASE_API_KEY=TODO_STAGING_FIREBASE_API_KEY

# TODO: Replace with the staging project's auth domain (e.g., your-staging-project.firebaseapp.com)
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=TODO_STAGING_PROJECT_ID.firebaseapp.com

# TODO: Replace with the staging Firebase project ID
NEXT_PUBLIC_FIREBASE_PROJECT_ID=TODO_STAGING_PROJECT_ID

# TODO: Replace with the staging storage bucket (e.g., your-staging-project.appspot.com)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=TODO_STAGING_PROJECT_ID.appspot.com

# TODO: Replace with the staging messaging sender ID (numeric)
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=TODO_STAGING_MESSAGING_SENDER_ID

# TODO: Replace with the staging Firebase app ID (e.g., 1:123456789012:web:abc123def456)
NEXT_PUBLIC_FIREBASE_APP_ID=TODO_STAGING_FIREBASE_APP_ID
